# FlexCart Backend (Example)
# Copy to .env and fill your values

# Server
PORT=5000
NODE_ENV=development

# Database (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=flexcart_db

# JWT
JWT_SECRET=change_me
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=change_me
JWT_REFRESH_EXPIRES_IN=30d

# Uploads
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads

# AI (optional)
AI_API_KEY=
AI_API_URL=https://api.openai.com/v1

# Frontend CORS origin
FRONTEND_URL=http://localhost:3000

# Public URL of the backend (needed when AI services are deployed separately)
# Example (Railway): https://<your-backend-service>.up.railway.app
BACKEND_PUBLIC_URL=http://localhost:5000

# Optional Python microservices
# VS_SERVICE_URL=http://localhost:5001
# REC_SERVICE_URL=http://localhost:5003
